# Скопируйте в .env и настройте под себя
DATABASE_URL=postgresql://msauser:msapass123@db:5432/msa_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# NCBI (рекомендуется)
NCBI_EMAIL=your_real_email@institution.edu
NCBI_API_KEY=your_optional_ncbi_key

# Режим демо (не требует интернета и API)
DEMO_MODE=false

DATA_DIR=/app/data/tasks
LOG_DIR=/app/logs